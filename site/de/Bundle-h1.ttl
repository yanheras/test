  fhir:language [ fhir:v "de"] ; # 
  fhir:type [ fhir:v "collection"] ; # 
  fhir:entry ( [
     fhir:fullUrl [
       fhir:v "http://somewhere.org/fhir/uv/myig/Provenance/h1-1"^^xsd:anyURI ;
